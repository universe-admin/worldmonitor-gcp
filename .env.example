# ============================================
# World Monitor — environment (self-host / docker-compose stack)
# Copy to `.env` (gitignored) and fill in. Generate hex with: openssl rand -hex 32
#
# Only the mandatory fields are listed. The dashboard runs without any optional
# feed/AI keys; add those later per the upstream docs if you want extra layers.
# (The Cloud Run MVP — gcp/deploy-mvp.sh — needs none of these.)
# ============================================

# ---- REQUIRED for docker-compose (stack won't start without these) ----
RELAY_SHARED_SECRET=          # AIS relay auth
REDIS_PASSWORD=               # Redis AUTH password
REDIS_TOKEN=                  # Upstash-compatible REST proxy bearer token

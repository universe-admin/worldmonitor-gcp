# ============================================
# World Monitor — environment (self-host stack)
# Copy to `.env` (gitignored) and fill in. Generate hex with: openssl rand -hex 32
# ============================================

# ---- REQUIRED for docker-compose (stack won't start without these) ----
RELAY_SHARED_SECRET=          # AIS relay auth
REDIS_PASSWORD=               # Redis AUTH password
REDIS_TOKEN=                  # Upstash-compatible REST proxy bearer token

# ---- MCP server: self-host API key(s) (comma-separated, format wm_<40 hex>) ----
# Validated by api/mcp/auth.ts against this var; pass as header X-WorldMonitor-Key
WORLDMONITOR_VALID_KEYS=

# ---- Local AI via Ollama (no cloud API keys) ----
# Container -> host Ollama. On GCP, point at the Ollama Cloud Run/GCE endpoint.
LLM_API_URL=                  # e.g. http://host.docker.internal:11434/v1/chat/completions
LLM_MODEL=                    # e.g. llama3.1:8b
LLM_API_KEY=ollama            # placeholder; Ollama ignores it

# ---- Optional cloud LLMs (leave blank if using Ollama) ----
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ---- Optional data feeds (each unlocks a layer; dashboard runs without them) ----
FINNHUB_API_KEY=
FRED_API_KEY=
EIA_API_KEY=
NASA_FIRMS_API_KEY=           # required for the fire-detection seeder
ACLED_EMAIL=
ACLED_PASSWORD=
AVIATIONSTACK_API=
AISSTREAM_API_KEY=
CLOUDFLARE_API_TOKEN=

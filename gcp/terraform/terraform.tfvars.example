# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored (real values).
#
# Only project_id is mandatory. Every other variable has a working default in
# variables.tf — override one only when you need to. Run `terraform apply` with
# just the line below to bring up the stack on defaults (region us-central1,
# domain aihumane.in, MVP sizing, placeholder images until Cloud Build pushes).

project_id = "aihumane-prod"

# ── Optional overrides (uncomment only what you need to change) ──────────────
# region               = "us-central1"
# domain               = "aihumane.in"
# db_high_availability  = true      # REGIONAL Cloud SQL once traffic warrants it
# deploy_redis          = false     # skip Memorystore for the cheapest MVP
# enable_ollama         = true      # self-hosted local AI (Phase 10)
# min_instances         = 1         # keep the MCP/backend warm (no cold starts)
# alert_email           = "you@example.com"   # enable Cloud Monitoring alerts
# image_app             = "us-central1-docker.pkg.dev/aihumane-prod/universe-monitor/app:latest"
